# ghostty +list-keybinds

keybind = option+shift+q=toggle_quick_terminal
keybind = super+h=toggle_quick_terminal

# navigate splits
keybind = super+j>super+j=goto_split:down
keybind = super+h>super+h=goto_split:left
keybind = super+k>super+k=goto_split:up
keybind = super+l>super+l=goto_split:right

# create splits
keybind = super+j>super+b=new_split:down
keybind = super+h>super+b=new_split:left
keybind = super+k>super+b=new_split:up
keybind = super+l>super+b=new_split:right
keybind = super+j>space=new_split:down
keybind = super+h>space=new_split:left
keybind = super+k>space=new_split:up
keybind = super+l>space=new_split:right
keybind = opt+r=activate_key_table:resize
keybind = resize/opt+l=resize_split:right,30
keybind = resize/opt+h=resize_split:left,30
keybind = resize/opt+k=resize_split:up,30
keybind = resize/opt+j=resize_split:down,30
keybind = resize/opt+r=deactivate_key_table
keybind = resize/escape=deactivate_key_table

# tabs 
keybind = ctrl+shift+comma=move_tab:-1
keybind = ctrl+shift+period=move_tab:1
keybind = cmd+b>cmd+z=toggle_split_zoom

# shell integration
keybind = cmd+up=jump_to_prompt:-2
keybind = ctrl+shift+z=jump_to_prompt:-1
keybind = ctrl+cmd+up=jump_to_prompt:-1
keybind = ctrl+cmd+down=jump_to_prompt:1
keybind = ctrl+shift+g=jump_to_prompt:-1

keybind = super+shift+w=close_tab:this
custom-shader = shaders/cursor_smear_original.glsl

macos-titlebar-style = tabs

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 0s

# begin auto-generated ghostty theme setting
theme = Rose Pine
# end auto-generated ghostty theme setting
