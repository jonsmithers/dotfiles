if [[ -n $CMUX_WORKSPACE_ID ]]; then
  b() {
    local surface_ref=$(cmux new-split down --json | jq  '.surface_ref' --raw-output )
    cmux send --surface "$surface_ref" "${@} && exit\n"
  }
  b_str() {
    local surface_ref=$(cmux new-split down --json | jq  '.surface_ref' --raw-output )
    cmux send --surface "$surface_ref" "${@} && exit\n"
  }
  n() {
    local errcode="$?"
    local title
    local prev_cmd="$(tail -n 1 $HISTFILE | sed 's/^[^;]*;//')"
    if [[ "$prev_cmd" = "n" ]]; then
      # get SECOND last command
      prev_cmd="$(tail -n 2 $HISTFILE | head -n 1 | sed 's/^[^;]*;//')"
    fi
    if [[ "$errcode" = "0" ]]; then
      title="${1:-✅ $prev_cmd}"
    else
      title="${1:-❌ $prev_cmd}"
    fi
    local body="$2"
    cmux notify --title "$title" --body "${body:-errcode $errcode}"
    return $errcode
  }
elif [[ "$TERM" = "xterm-ghostty" && "$(uname -s)" = "Darwin" ]]; then
  b() {
    osascript <<EOF
tell application "Ghostty"
	set currentTerm to focused terminal of selected tab of front window
	set newTerm to split currentTerm direction down
	input text "${@} && exit\r" to newTerm
                    focus currentTerm
end tell
EOF
  }
  function b_str() {
    osascript <<EOF
tell application "Ghostty"
	set currentTerm to focused terminal of selected tab of front window
	set newTerm to split currentTerm direction down
	input text "${@} && exit\r" to newTerm
                    focus currentTerm
end tell
EOF
  }
  notify() {
    local errcode="$?"
    local title
    local prev_cmd="$(tail -n 1 $HISTFILE | sed 's/^[^;]*;//')"
    if [[ "$errcode" = "0" ]]; then
      title="${1:-✅ $prev_cmd}"
    else
      title="${1:-❌ $prev_cmd}"
    fi
    local body="$2"
    printf "\033]777;notify;$title;$body\033\\"
    return $errcode
  }
  alias n=notify
fi
if [[ "$TERM" = "xterm-kitty" ]]; then
  alias rg='rg --hyperlink-format=kitty'
  [[ $print_emojis ]] && echo -n 🐱
  alias icat="kitty +kitten icat"
  alias hg="kitty +kitten hyperlinked_grep "
  compdef hg=rg
  # https://www.baeldung.com/linux/background-process-get-exit-code

  if has fzf; then
    function fzfimg {
      # https://github.com/junegunn/fzf/pull/3567
      fzf -q '.png$ | .jpg$ | .gif$' --preview 'kitty icat --clear --transfer-mode=memory --stdin=no --place="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}@0x0" {}'
    }
  fi

  b() {
    str=''
    for arg in "$@"; do
      if [[ "$arg" =~ ' ' ]]; then
        str="$str '$arg'"
      else
        str="$str $arg"
      fi
    done
    echo "$str"

    # the currently-focused window id (which is different from the current window id $KITTY_WINDOW_ID)
    local this_window="$(kitty @ ls | jq '.[] | select(.is_focused) | .tabs.[] | select(.is_focused) | .windows.[] | select(.is_focused) | .id')"
    # this_window="${this_window:-$KITTY_WINDOW_ID}"
    local other_window="$(kitty @ launch --cwd=current --location=hsplit --bias=10)"
    # kitty @ send-text --match "id:$other_window" " $@"' \\\r && sleep 2 && exit\n'
    kitty @ send-text --match "id:$other_window" "$str"' \\\r && sleep 2 && exit\n'
    [[ -n "$other_window" ]] && kitty @ focus-window --match "id:$this_window"
  }
  b_str() {
    # the currently-focused window id (which is different from the current window id $KITTY_WINDOW_ID)
    local this_window="$(kitty @ ls | jq '.[] | select(.is_focused) | .tabs.[] | select(.is_focused) | .windows.[] | select(.is_focused) | .id')"
    if [[ -z "$this_window" ]]; then
      set -x
      echo "no focused window"
      echo "see ~/error.txt"
      echo "$(kitty @ ls | jq '.[] | .tabs.[] | .windows.[]')" > ~/error.txt
    fi
    # this_window="${this_window:-$KITTY_WINDOW_ID}"
    local other_window="$(kitty @ launch --cwd=current --location=hsplit --bias=10)"
    kitty @ send-text --match "id:$other_window" " $@"' \\\r && sleep 2 && exit\n'
    [[ -n "$other_window" && -n "$this_window" ]] && kitty @ focus-window --match "id:$this_window"
    set +x
  }

  notify() {
    local errcode="$?"
    local title
    local prev_cmd="$(tail -n 1 $HISTFILE | sed 's/^[^;]*;//')"
    if [[ "$errcode" = "0" ]]; then
      title="${1:-✅ $prev_cmd}"
    else
      title="${1:-❌ $prev_cmd}"
    fi
    local body="$2"
    printf '\x1b]99;i=1:d=0;'"$title"'\x1b\\'
    printf '\x1b]99;i=1:d=1:p=body;'"$body"'\x1b\\'
    printf '\e[?5h'; sleep 0.1 ; printf '\e[?5l'
    return $errcode
  }
  alias n=notify
  function nvim_kitty_post_hook_2() {
    local errcode="$?"
    local kitty_window_id="$1"
    if [[ "$errcode" != "0" ]]; then
      kitty @ focus-window --match id:"$kitty_window_id" # kitty seems to only place the overlay on the active window
      kitty @ action move_window_to_top
      kitty @ action show_last_command_output
      # kitty @ launch --match id:"$kitty_window_id" --cwd=current --stdin-source=@last_cmd_output --type=overlay nvim -c "set relativenumber" -c "set buftype=nofile" -
      # TODO how do I get colors????
      # kitty @ launch --match id:"$kitty_window_id" --cwd=current --stdin-source=@last_cmd_output --type=overlay less -R --use-color
    else
      echo
      echo '✅'
      echo closing...
      sleep 2
    fi
    exit
  }
  rk_mark() {
    kitty @ --password "$KITTY_RC_PASSWORD" create-marker --match all text 3 "$1"
  }
  rk_unmark() {
    kitty @ --password "$KITTY_RC_PASSWORD" remove-marker --match all
  }
  [[ $print_emojis ]] && echo -n 🐈
fi
