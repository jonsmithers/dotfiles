has ffmpeg && function mov_half_res() {
  if [[ -z "$1" ]]; then
    echo 'mov_half <input> [output]'
    return 1
  fi
  ( set -x; ffmpeg -i "$1" -vf "scale=trunc(iw/4)*2:trunc(ih/4)*2" "${2:-output.mp4}" )
}
has ffmpeg && function mov_double_speed() {
  if [[ -z "$1" ]]; then
    echo 'mov_half <input> [output]'
    return 1
  fi
  ( set -x; ffmpeg -i "$1" -filter:v "setpts=PTS/2,fps=24" -an "${2:-output.mp4}" )
  # setpts=PTS/2 devides each frame's presentation timestamp by 2
  # fps=24 outputs 24 frames per second
  # -an removes audio
  # (https://superuser.com/questions/1261678/how-do-i-speed-up-a-video-by-60x-in-ffmpeg)
}
has ffmpeg && function mov_speed_up() {
  if [[ -z "$2" ]]; then
    echo 'mov_half <input> <speed multiplier> [output]'
    echo
    echo 'This will speed up <input> by <speed multiplier>x.'
    return 1
  fi
  ( set -x; ffmpeg -i "$1" -filter:v "setpts=PTS/${2},fps=24" -an "${3:-output.mp4}" )
}

